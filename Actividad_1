// a) Tamaño de la colección companies
let tamc = db.companies.dataSize()
print(`Tamaño: ${tamc}`)
// b) Total de compañias
let tcom = db.companies.countDocuments()
print(`Total compañías: ${tcom}`)
// c) Total compañías fundadas en los años 1996, 1997, 2001 y 2005
let com_a = db.companies.aggregate([ {$match: {founded_year:{$in:[1996,1997,2001,2005]}} },
                       	 {$group: {_id:"$founded_year",total:{$sum:1}} },
                         {$project: {_id:0,Año:"$_id",total:1}},
                         {$sort: {Año:1} }
                       ])
print('\nTotal compañías fundadas en los años 1996, 1997, 2001 y 2005')
print(com_a)
// d) Compañías que se dedican a «web» o «mobile» mostrando: nombre, descripción, número de empleados, e-mail, año, mes y día de su fundación. 
