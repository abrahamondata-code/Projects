// g) Compañías fundadas entre los años 2001 y 2005, con 500 empleados o más, dedicados a la musica o a los videojuegos, mostrando: nombre, URL, usuario de Twitter y número de empleados
let com_amv = db.companies.aggregate([ {$match: {founded_year:{$gte:2001,$lte:2005},
                                   number_of_employees:{$gte:500},
